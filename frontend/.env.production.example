# Public backend base URL (without trailing slash).
# Either VITE_API_URL or VITE_API_BASE_URL can be used.
VITE_API_URL=https://your-backend-domain

# Optional. If omitted, frontend auto-derives websocket URL from VITE_API_URL.
# Keep this only when ws endpoint is on a different domain/path.
VITE_WS_BASE_URL=wss://your-backend-domain/api/ws/mood

APP_NAME=Mood Detection API
API_PREFIX=/api
SECRET_KEY=replace-with-long-random-secret
ENCRYPTION_KEY=replace-with-generated-fernet-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MongoDB Atlas example:
# mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=replace-with-mongodb-atlas-uri
MONGODB_DB_NAME=mood_detection_system
USE_MOCK_DB=false

# You can provide CORS_ORIGINS as a JSON array or comma-separated values.
# JSON array example:
# CORS_ORIGINS=["https://your-app.vercel.app"]
# Comma-separated example:
# CORS_ORIGINS=https://your-app.vercel.app,https://www.your-app.vercel.app
CORS_ORIGINS=["https://your-app.vercel.app"]

RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_API=60/minute
